APP_NAME=Checklist App API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=ckecklist
DB_USER=postgres
DB_PASSWORD=password
DB_ECHO=false

# Stripe Keys
PUBLISHABLE_KEY=demo-key
SECRET_KEY=demo-key
STRIPE_WEBHOOK_SECRET=demo-key

# Media Upload Configuration
# For production, set this to a writable directory path
# If not set, will use 'uploads/media' or fallback to temp directory
UPLOAD_DIR=/var/www/uploads/media
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=your-aws-region
S3_BUCKET_ARN=your-s3-bucket-arn